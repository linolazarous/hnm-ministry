# ======================
# Netlify Deployment Configuration
# ======================
# These should be set in Netlify's environment variables dashboard
NETLIFY_SITE_ID=your-site-id
NETLIFY_AUTH_TOKEN=your-auth-token

# ======================
# Frontend Environment (Vite-Exposed)
# ======================
# These will be prefixed with VITE_ and exposed to client-side
VITE_APP_ENV=production
VITE_API_BASE_URL=https://api.hnm.org
VITE_APP_VERSION=$npm_package_version

# ======================
# Frontend Services
# ======================
VITE_FACEBOOK_APP_ID=your-app-id
VITE_FACEBOOK_PAGE_ID=your-page-id
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
VITE_MAGIC_PUB_KEY=pk_live_your_key
VITE_YOUTUBE_API_KEY=your-yt-api-key

# ======================
# Backend/Serverless Only (Never exposed to frontend)
# ======================
# These should ONLY be set in Netlify's build environment variables
FAUNADB_SECRET=your-fauna-secret
FACEBOOK_APP_SECRET=your-app-secret
FACEBOOK_CLIENT_TOKEN=your-client-token
STRIPE_SECRET_KEY=sk_live_your_key
MAGIC_SECRET_KEY=sk_live_your_key
YOUTUBE_CLIENT_SECRET=your-yt-client-secret

# ======================
# Monitoring & Observability
# ======================
SENTRY_AUTH_TOKEN=your-sentry-token
SENTRY_PROJECT=hnm-ministry
SENTRY_ORG=hnm-ministry
SENTRY_DSN=https://your-dsn@sentry.io/your-project

# ======================
# Build Optimization
# ======================
NODE_VERSION=18.x
NODE_ENV=production
